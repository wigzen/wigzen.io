<style>
  /* ── Page wrapper ── */
  .resume {
    padding-block: var(--section-pad);
    padding-inline: var(--gutter);
    background: var(--clr-bg);
  }

  /* ── Shared section header (index + heading) ── */
  .resume__section-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 4rem;
  }

  .resume__section-index {
    font-size: 0.8rem;
    color: var(--clr-text-muted);
    letter-spacing: 0.1em;
  }

  .resume__section-heading {
    font-size: var(--text-h2);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--clr-text);
  }

  /* ── Header ── */
  .resume__header {
    padding-bottom: var(--section-pad);
    border-bottom: 1px solid var(--clr-border);
    margin-bottom: var(--section-pad);
  }

  .resume__header-index {
    font-size: 0.8rem;
    color: var(--clr-text-muted);
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .resume__name {
    font-size: var(--text-h1);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 0.9;
    color: var(--clr-text);
  }

  .resume__role {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--clr-text-muted);
    margin-top: 1.5rem;
  }

  .resume__contact {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .resume__contact-item {
    font-size: 0.85rem;
    color: var(--clr-text-muted);
    transition: color 0.2s;
  }

  .resume__contact-item a {
    color: var(--clr-text-muted);
    transition: color 0.2s;
  }

  .resume__contact-item a:hover,
  .resume__contact-item:hover {
    color: var(--clr-accent);
  }

  .resume__actions {
    display: flex;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .resume__btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-full);
    font-size: 0.9rem;
    color: var(--clr-text);
    transition: background 0.3s, color 0.3s, border-color 0.3s;
  }

  .resume__btn:hover {
    background: var(--clr-accent);
    color: var(--clr-bg);
    border-color: var(--clr-accent);
  }

  .resume__btn--primary {
    background: var(--clr-accent);
    color: var(--clr-bg);
    border-color: var(--clr-accent);
  }

  .resume__btn--primary:hover {
    background: transparent;
    color: var(--clr-text);
    border-color: var(--clr-border);
  }

  /* ── Shared row layout (Experience, Projects, Education) ── */
  .resume__list {
    display: flex;
    flex-direction: column;
  }

  .resume__row {
    display: grid;
    grid-template-columns: 14ch 2px 1fr;
    gap: 2rem;
    padding-block: 3rem;
    border-top: 1px solid var(--clr-border);
    transition: background 0.3s ease;
  }

  .resume__row:last-child {
    border-bottom: 1px solid var(--clr-border);
  }

  .resume__row:hover {
    background: var(--clr-surface);
  }

  .resume__row-date {
    font-size: 0.8rem;
    color: var(--clr-text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding-top: 0.35rem;
  }

  .resume__accent {
    width: 2px;
    align-self: stretch;
    background: var(--clr-accent);
    border-radius: 1px;
    transition: width 0.3s ease;
  }

  .resume__row:hover .resume__accent {
    width: 4px;
  }

  .resume__row-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .resume__row-title {
    font-size: var(--text-h4);
    font-weight: 700;
    color: var(--clr-text);
    line-height: 1.1;
  }

  .resume__row-subtitle {
    font-size: 0.85rem;
    color: var(--clr-accent-text);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .resume__row-desc {
    font-size: 0.95rem;
    color: var(--clr-text-muted);
    line-height: 1.6;
    max-width: 55ch;
    margin-top: 0.25rem;
  }

  .resume__row-desc p {
    margin-bottom: 0.5rem;
  }

  .resume__row-desc p:last-child {
    margin-bottom: 0;
  }

  .resume__row-link {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    color: var(--clr-text-muted);
    margin-top: 0.5rem;
    align-self: flex-start;
    transition: border-color 0.2s, color 0.2s;
  }

  .resume__row-link:hover {
    border-color: var(--clr-accent);
    color: var(--clr-accent);
  }

  /* ── Skills grid ── */
  .resume__skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3rem;
  }

  .resume__skill-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    background: var(--clr-surface);
    transition: border-color 0.3s ease;
  }

  .resume__skill-card:hover {
    border-color: var(--clr-accent);
  }

  .resume__skill-category {
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--clr-text);
  }

  .resume__skill-items {
    font-size: 0.85rem;
    color: var(--clr-text-muted);
    line-height: 1.8;
  }

  /* ── Section spacing ── */
  .resume__block {
    margin-bottom: var(--section-pad);
  }

  .resume__block:last-child {
    margin-bottom: 0;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .resume__row {
      grid-template-columns: 1fr;
      gap: 0;
      padding-block: 2.5rem;
    }

    .resume__accent {
      width: 40px;
      height: 2px;
      align-self: auto;
      margin-block: 1rem;
    }

    .resume__row:hover .resume__accent {
      width: 60px;
      height: 2px;
    }

    .resume__row-date {
      padding-top: 0;
    }

    .resume__actions {
      flex-direction: column;
    }

    .resume__btn {
      justify-content: center;
    }
  }

  @media (max-width: 640px) {
    .resume__skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

