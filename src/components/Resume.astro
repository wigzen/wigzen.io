<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Animate rows on scroll
  document.querySelectorAll("[data-resume-row]").forEach((row) => {
    gsap.set(row, { opacity: 0, y: 40 });
    gsap.to(row, {
      opacity: 1,
      y: 0,
      duration: 0.6,
      ease: "power2.out",
      scrollTrigger: {
        trigger: row,
        start: "top 85%",
        toggleActions: "play none none none",
      },
    });

    const accent = (row as HTMLElement).querySelector(".resume__accent") as HTMLElement;
    if (accent) {
      row.addEventListener("mouseenter", () => {
        if (window.innerWidth > 768) {
          gsap.to(accent, { width: 4, duration: 0.3, ease: "power2.out" });
        } else {
          gsap.to(accent, { width: 60, duration: 0.3, ease: "power2.out" });
        }
      });
      row.addEventListener("mouseleave", () => {
        if (window.innerWidth > 768) {
          gsap.to(accent, { width: 2, duration: 0.3, ease: "power2.out" });
        } else {
          gsap.to(accent, { width: 40, duration: 0.3, ease: "power2.out" });
        }
      });
    }
  });

  // Animate skill cards on scroll
  document.querySelectorAll("[data-resume-card]").forEach((card) => {
    gsap.set(card, { opacity: 0, y: 30 });
    gsap.to(card, {
      opacity: 1,
      y: 0,
      duration: 0.5,
      ease: "power2.out",
      scrollTrigger: {
        trigger: card,
        start: "top 85%",
        toggleActions: "play none none none",
      },
    });
  });

  // Header fade in
  const header = document.querySelector("[data-resume-header]");
  if (header) {
    gsap.from(header, { opacity: 0, y: 20, duration: 0.8, ease: "power2.out", delay: 0.2 });
  }

  // Contact Me button
  document.getElementById("resume-contact-btn")?.addEventListener("click", () => {
    window.location.href = "mailto:vikaslodh2@gmail.com";
  });
</script>
