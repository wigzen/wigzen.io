---
import InteractiveDotGrid from "../ui/InteractiveDotGrid.astro";
---

<section id="home" class="hero">
  <div class="hero__bg">
    <InteractiveDotGrid
      baseColor="#78716c"
      activeColor="#a8ff51"
      centerHole={true}
    />
  </div>

  <div class="hero__ambient" aria-hidden="true">
    <div class="hero__orb"></div>
  </div>

  <div class="hero__content">
    <p class="hero__eyebrow" data-intro>Mumbai, India &nbsp;·&nbsp; Available</p>
    <h1 class="hero__name" data-hero-parallax>
      <span class="hero__line" data-name-line>VIKAS</span>
      <span class="hero__line hero__line--right" data-name-line>LODH</span>
    </h1>
    <div class="hero__divider" data-intro aria-hidden="true"></div>
    <p class="hero__tagline" data-intro>I design systems, not just features.</p>
    <div class="hero__meta">
      <span class="hero__role" data-intro>Full Stack Engineer / Systems Architect</span>
      <a href="#work" class="hero__cta" data-magnetic data-intro aria-label="See my work">See Work ↓</a>
    </div>
  </div>

  <p class="hero__scroll" data-intro>Scroll</p>
</section>

<style>
  .hero {
    min-height: 100dvh;
    position: relative;
    padding-inline: var(--gutter);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: auto;
    overflow: hidden;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    pointer-events: none;
  }

  .hero__eyebrow {
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--clr-text-muted);
    margin-bottom: 1.5rem;
  }

  .hero__name {
    font-size: var(--text-hero);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 0.9;
    color: var(--clr-text);
    overflow: hidden;
  }

  .hero__line {
    display: block;
    overflow: hidden;
  }

  .hero__line--right {
    text-align: right;
  }

  .hero__tagline {
    font-size: clamp(1rem, 2vw, 1.5rem);
    color: var(--clr-accent-text);
    font-weight: 500;
    letter-spacing: 0.02em;
    margin-top: 1.5rem;
  }

  .hero__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 2rem;
    pointer-events: auto;
  }

  .hero__role {
    font-size: 1rem;
    color: var(--clr-text-muted);
  }

  .hero__cta {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border: 1px solid var(--clr-border);
    border-radius: 2rem;
    font-size: 0.9rem;
    color: var(--clr-text);
    transition: background 0.3s, color 0.3s, border-color 0.3s;
  }

  .hero__cta:hover {
    background: var(--clr-accent);
    color: var(--clr-bg);
    border-color: var(--clr-accent);
  }

  .hero__scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    translate: -50% 0;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--clr-text-muted);
    z-index: 2;
  }

  /* Mobile-only elements — hidden on desktop */
  .hero__ambient { display: none; }
  .hero__divider { display: none; }

  @media (max-width: 768px) {
    .hero__bg { display: none; }

    /* Ambient orb */
    .hero__ambient {
      display: block;
      position: absolute;
      inset: 0;
      z-index: 0;
      overflow: hidden;
      pointer-events: none;
    }

    .hero__orb {
      position: absolute;
      width: 70vw;
      height: 70vw;
      top: 12%;
      right: -15%;
      border-radius: 50%;
      background: radial-gradient(
        circle at center,
        rgba(168, 255, 81, 0.12) 0%,
        rgba(168, 255, 81, 0.04) 40%,
        transparent 70%
      );
      filter: blur(60px);
      animation: orb-drift 8s var(--ease-smooth) infinite alternate;
      will-change: transform;
    }

    :global(html.theme-dark) .hero__orb,
    :global(body.theme-dark) .hero__orb {
      background: radial-gradient(
        circle at center,
        rgba(168, 255, 81, 0.15) 0%,
        rgba(168, 255, 81, 0.05) 40%,
        transparent 70%
      );
    }

    @keyframes orb-drift {
      0%   { transform: translate(0, 0) scale(1); }
      100% { transform: translate(-8vw, 6vh) scale(1.1); }
    }

    /* Hero layout — content at bottom */
    .hero {
      padding-inline: var(--gutter);
      justify-content: flex-end;
      padding-bottom: 6rem;
    }

    /* Eyebrow */
    .hero__eyebrow {
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      margin-bottom: 1.5rem;
      font-weight: 500;
    }

    /* Name: bleed to edges, oversized */
    .hero__name {
      font-size: clamp(56px, 18vw, 110px);
      line-height: 0.85;
      letter-spacing: -0.03em;
      margin-inline: calc(var(--gutter) * -1);
      padding-inline: var(--gutter);
    }

    /* Second line: outlined stroke */
    .hero__line--right {
      text-align: left;
      color: transparent;
      -webkit-text-stroke: 1.5px var(--clr-text);
      paint-order: stroke fill;
      margin-top: 0.05em;
    }

    /* Accent divider */
    .hero__divider {
      display: block;
      width: 3rem;
      height: 2px;
      background: var(--clr-accent-fill);
      margin-top: 1.5rem;
      margin-bottom: 1.25rem;
      transform-origin: left center;
    }

    /* Tagline */
    .hero__tagline {
      font-size: clamp(0.95rem, 3.8vw, 1.2rem);
      margin-top: 0;
      font-weight: 500;
      line-height: 1.35;
      max-width: 20ch;
    }

    /* Meta: editorial strip */
    .hero__meta {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 0;
      margin-top: 2rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--clr-border);
    }

    .hero__role {
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 500;
      max-width: 50%;
    }

    .hero__cta {
      padding: 0.6rem 1.4rem;
      font-size: 0.75rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      font-weight: 500;
      border: 1px solid var(--clr-accent);
      color: var(--clr-accent);
      min-height: 44px;
      display: inline-flex;
      align-items: center;
    }

    .hero__cta:active {
      background: var(--clr-accent-fill);
      color: var(--clr-bg);
    }

    /* Scroll indicator pulse */
    .hero__scroll {
      bottom: 1.5rem;
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      animation: scroll-pulse 2s var(--ease-smooth) 3s 3;
    }

    @keyframes scroll-pulse {
      0%, 100% { opacity: 0.4; }
      50% { opacity: 1; }
    }
  }

  @media (max-width: 480px) {
    .hero__name {
      font-size: clamp(44px, 16vw, 80px);
    }

    .hero__line--right {
      -webkit-text-stroke: 1px var(--clr-text);
    }

    .hero__orb {
      width: 90vw;
      height: 90vw;
      top: 8%;
      right: -25%;
      filter: blur(50px);
    }

    .hero__meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .hero__role {
      max-width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__orb { animation: none; }
    .hero__scroll { animation: none; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { SplitText } from "gsap/SplitText";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(SplitText, ScrollTrigger);

  function animateHero() {
    const nameLines = document.querySelectorAll("[data-name-line]");
    if (!nameLines.length) return;

    const isMobile = window.matchMedia("(max-width: 768px)").matches;

    const split = SplitText.create("[data-name-line]", {
      type: "chars",
      mask: "chars",
    });

    const tl = gsap.timeline();

    if (isMobile) {
      // Mobile entry sequence
      tl.fromTo(".hero__orb",
        { opacity: 0, scale: 0.6 },
        { opacity: 1, scale: 1, duration: 1.2, ease: "expo.out" }
      );
      tl.from(split.chars, {
        yPercent: 120,
        stagger: { amount: 0.4, from: "start" },
        duration: 0.9,
        ease: "expo.out",
      }, 0.2);
      tl.fromTo(".hero__divider",
        { scaleX: 0 },
        { scaleX: 1, duration: 0.6, ease: "expo.out" },
        "-=0.3"
      );
      tl.from("[data-intro]", {
        opacity: 0,
        y: 20,
        stagger: 0.08,
        duration: 0.5,
        ease: "power2.out",
      }, "-=0.2");
    } else {
      // Desktop entry (unchanged)
      tl.from(split.chars, {
        yPercent: 110,
        stagger: { amount: 0.5 },
        duration: 1.0,
        ease: "expo.out",
      }).from(
        "[data-intro]",
        {
          opacity: 0,
          y: 16,
          stagger: 0.1,
          duration: 0.5,
          ease: "power2.out",
        },
        "-=0.3"
      );
    }

    // Parallax on scroll (desktop only)
    if (!isMobile && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      const parallaxTarget = document.querySelector("[data-hero-parallax]");
      if (parallaxTarget) {
        gsap.to(parallaxTarget, {
          yPercent: -15,
          ease: "none",
          scrollTrigger: {
            trigger: "#home",
            start: "top top",
            end: "bottom top",
            scrub: true,
          },
        });
      }
    }
  }

  if ((window as any).__introComplete) {
    animateHero();
  } else {
    document.addEventListener("intro:complete", animateHero, { once: true });
  }
</script>
