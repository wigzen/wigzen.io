---
import { getCollection } from "astro:content";

const experiences = (await getCollection("experience")).sort(
  (a, b) => a.data.index - b.data.index
);

const roles = experiences.map((exp) => ({
  date: `${exp.data.startDate} — ${exp.data.endDate}`,
  title: exp.data.title,
  company: exp.data.company,
  description: exp.data.description,
}));
---

<section id="experience" class="exp">
  <div class="exp__header">
    <span class="exp__index">(03)</span>
    <h2 class="exp__heading">
      <span class="exp__heading-inner">Experience</span>
      <span class="exp__heading-clip" aria-hidden="true"></span>
    </h2>
  </div>

  <div class="exp__list">
    <div class="exp__timeline-track" aria-hidden="true">
      <div class="exp__timeline-fill"></div>
      <div class="exp__timeline-dot"></div>
    </div>
    {roles.map((r) => (
      <article class="exp__row" data-exp-row>
        <span class="exp__date">{r.date}</span>
        <div class="exp__accent"></div>
        <div class="exp__content">
          <h3 class="exp__title">{r.title}</h3>
          <p class="exp__company">{r.company}</p>
          <p class="exp__desc">{r.description}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .exp {
    padding-block: var(--section-pad);
    padding-inline: var(--gutter);
    background: var(--clr-bg);
  }

  .exp__header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 4rem;
  }

  .exp__index {
    font-size: 0.8rem;
    color: var(--clr-text-muted);
    letter-spacing: 0.1em;
    opacity: 0;
  }

  .exp__heading {
    position: relative;
    overflow: hidden;
    font-size: var(--text-h2);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--clr-text);
  }

  .exp__heading-inner {
    display: block;
    /* starts hidden — GSAP reveals it */
    opacity: 0;
  }

  .exp__heading-clip {
    position: absolute;
    inset: 0;
    background: var(--clr-accent);
    transform-origin: left;
    /* starts covering the text — GSAP wipes it away */
  }

  .exp__list {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .exp__timeline-track {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    /* left is set at runtime via JS */
    pointer-events: none;
  }

  .exp__timeline-fill {
    width: 2px;
    height: 0%;
    background: var(--clr-accent);
    position: absolute;
    top: 0;
    left: 0;
  }

  .exp__timeline-dot {
    position: absolute;
    left: -4px;
    top: 0;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--clr-accent);
    box-shadow: 0 0 12px var(--clr-accent), 0 0 24px rgba(168, 255, 81, 0.4);
  }

  .exp__row {
    display: grid;
    grid-template-columns: 1fr 2px 2fr;
    gap: 2rem;
    padding-block: 3rem;
    border-top: 1px solid var(--clr-border);
    position: relative;
    transition: background 0.3s ease;
  }

  .exp__row:last-child {
    border-bottom: 1px solid var(--clr-border);
  }

  .exp__row:hover {
    background: var(--clr-border);
  }

  .exp__date {
    font-size: 0.8rem;
    color: var(--clr-text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding-top: 0.35rem;
  }

  .exp__accent {
    width: 2px;
    align-self: stretch;
    background: var(--clr-accent);
    border-radius: 1px;
    transition: width 0.3s ease;
  }

  .exp__row:hover .exp__accent {
    width: 4px;
  }

  .exp__content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .exp__title {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 700;
    color: var(--clr-text);
    line-height: 1.1;
  }

  .exp__company {
    font-size: 0.85rem;
    color: var(--clr-accent-text);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .exp__desc {
    font-size: 0.95rem;
    color: var(--clr-text-muted);
    line-height: 1.6;
    max-width: 55ch;
    margin-top: 0.25rem;
  }

  @media (max-width: 768px) {
    .exp__timeline-track {
      display: none;
    }

    .exp__row {
      grid-template-columns: 1fr;
      gap: 0;
      padding-block: 2.5rem;
    }

    .exp__accent {
      width: 40px;
      height: 2px;
      align-self: auto;
      margin-block: 1rem;
    }

    .exp__row:hover .exp__accent {
      width: 60px;
      height: 2px;
    }

    .exp__date {
      padding-top: 0;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const expSection = document.querySelector(".exp") as HTMLElement;
  const headingInner = document.querySelector(".exp__heading-inner") as HTMLElement;
  const headingClip = document.querySelector(".exp__heading-clip") as HTMLElement;
  const expIndex = document.querySelector(".exp__index") as HTMLElement;

  if (expSection && headingInner && headingClip && expIndex) {
    const headingTl = gsap.timeline({
      scrollTrigger: {
        trigger: expSection,
        start: "top 75%",
        toggleActions: "play none none none",
      },
    });

    // 1. Fade in the index label
    headingTl.to(expIndex, { opacity: 1, duration: 0.4, ease: "power2.out" });

    // 2. Reveal text (opacity 0→1) slightly before the wipe completes
    headingTl.to(headingInner, { opacity: 1, duration: 0.1, ease: "none" }, "-=0.5");

    // 3. Wipe the clip overlay away left→right
    headingTl.to(headingClip, { scaleX: 0, duration: 0.7, ease: "power3.inOut" }, "-=0.5");
  }

  const rows = document.querySelectorAll("[data-exp-row]");

  rows.forEach((row, i) => {
    gsap.set(row, { opacity: 0, y: 40 });

    gsap.to(row, {
      opacity: 1,
      y: 0,
      duration: 0.6,
      ease: "power2.out",
      delay: i * 0.15,
      scrollTrigger: {
        trigger: row,
        start: "top 80%",
        toggleActions: "play none none none",
      },
    });

    const accent = row.querySelector(".exp__accent") as HTMLElement;
    if (accent) {
      row.addEventListener("mouseenter", () => {
        gsap.to(accent, { width: 4, duration: 0.3, ease: "power2.out" });
      });
      row.addEventListener("mouseleave", () => {
        gsap.to(accent, { width: 2, duration: 0.3, ease: "power2.out" });
      });
    }
  });
</script>
