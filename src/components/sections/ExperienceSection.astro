---
import { getCollection } from "astro:content";

const experiences = (await getCollection("experience")).sort(
  (a, b) => a.data.index - b.data.index
);

const roles = experiences.map((exp) => ({
  date: `${exp.data.startDate} — ${exp.data.endDate}`,
  title: exp.data.title,
  company: exp.data.company,
  description: exp.data.description,
}));
---

<section id="experience" class="exp">
  <div class="exp__header">
    <span class="exp__index">(03)</span>
    <h2 class="exp__heading">
      <span class="exp__heading-inner">Experience</span>
      <span class="exp__heading-clip" aria-hidden="true"></span>
    </h2>
  </div>

  <div class="exp__list">
    <div class="exp__timeline-track" aria-hidden="true">
      <div class="exp__timeline-fill"></div>
      <div class="exp__timeline-dot"></div>
    </div>
    {roles.map((r) => (
      <article class="exp__row" data-exp-row>
        <span class="exp__date">{r.date}</span>
        <div class="exp__accent"></div>
        <div class="exp__content">
          <h3 class="exp__title">{r.title}</h3>
          <p class="exp__company">{r.company}</p>
          <p class="exp__desc">{r.description}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .exp {
    padding-block: var(--section-pad);
    padding-inline: var(--gutter);
    background: var(--clr-bg);
  }

  .exp__header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 4rem;
  }

  .exp__index {
    font-size: 0.8rem;
    color: var(--clr-text-muted);
    letter-spacing: 0.1em;
    opacity: 0;
  }

  .exp__heading {
    position: relative;
    overflow: hidden;
    font-size: var(--text-h2);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--clr-text);
  }

  .exp__heading-inner {
    display: block;
    /* starts hidden — GSAP reveals it */
    opacity: 0;
  }

  .exp__heading-clip {
    position: absolute;
    inset: 0;
    background: var(--clr-bg);
    transform-origin: left;
    /* starts covering the text — GSAP wipes it away */
  }

  .exp__list {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .exp__timeline-track {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    /* left is set at runtime via JS */
    pointer-events: none;
  }

  .exp__timeline-fill {
    width: 2px;
    height: 0%;
    background: var(--clr-accent);
    position: absolute;
    top: 0;
    left: 0;
  }

  .exp__timeline-dot {
    position: absolute;
    left: -4px;
    top: 0;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--clr-accent);
    box-shadow: none;
    transform: translateY(-50%);
  }

  :global(html.theme-dark) .exp__timeline-dot {
    box-shadow: 0 0 12px var(--clr-accent-fill), 0 0 24px color-mix(in srgb, var(--clr-accent-fill) 40%, transparent);
  }

  .exp__row {
    display: grid;
    grid-template-columns: 1fr 2px 2fr;
    gap: 2rem;
    padding-block: 3rem;
    border-top: 1px solid var(--clr-border);
    position: relative;
    transition: opacity 0.4s ease, background 0.4s ease;
  }

  .exp__row:last-child {
    border-bottom: 1px solid var(--clr-border);
  }

  .exp__row:hover {
    /* opacity: 1 !important; */
    background: var(--clr-border);
  }

  /* Spotlight: when any row has is-active sibling, dim non-active rows */
  .exp__list:has(.is-active) .exp__row:not(.is-active) {
    opacity: 0.3;
  }

  /* Active row */
  .exp__row.is-active {
    opacity: 1 !important;
    background: color-mix(in srgb, var(--clr-accent-fill) 4%, transparent);
    /* border-left: 2px solid var(--clr-accent); */
  }

  .exp__date {
    font-size: 0.8rem;
    color: var(--clr-text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding-top: 0.35rem;
  }

  .exp__accent {
    width: 2px;
    align-self: stretch;
    background: var(--clr-accent-fill);
    border-radius: 1px;
    transition: width 0.3s ease; 
    opacity: 0;
  }

  .exp__row:hover .exp__accent {
    width: 2px;
  }

  .exp__content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .exp__title {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 700;
    color: var(--clr-text);
    line-height: 1.1;
  }

  .exp__company {
    font-size: 0.85rem;
    color: var(--clr-accent-text);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .exp__desc {
    font-size: 0.95rem;
    color: var(--clr-text-muted);
    line-height: 1.6;
    max-width: 55ch;
    margin-top: 0.25rem;
  }

  @media (max-width: 768px) {
    .exp__timeline-track {
      display: none;
    }

    .exp__row {
      grid-template-columns: 1fr;
      gap: 0;
      padding-block: 2.5rem;
    }

    .exp__accent {
      width: 40px;
      height: 2px;
      align-self: auto;
      margin-block: 1rem;
    }

    .exp__row:hover .exp__accent {
      /* width: 60px; */
      height: 2px;
    }

    .exp__date {
      padding-top: 0;
    }

    /* Disable spotlight on mobile */
    .exp__list:has(.is-active) .exp__row:not(.is-active) {
      opacity: 1;
    }
    .exp__row.is-active {
      background: transparent;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .exp__heading-inner { opacity: 1; }
    .exp__heading-clip { display: none; }
    .exp__index { opacity: 1; }
    .exp__row { transition: none; }
    .exp__timeline-track { display: none; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function initExperienceAnimations() {
    const localTriggers: globalThis.ScrollTrigger[] = [];
    const hoverListeners: { el: Element; enter: () => void; leave: () => void }[] = [];

    const expSection = document.querySelector(".exp") as HTMLElement;
    const headingInner = document.querySelector(".exp__heading-inner") as HTMLElement;
    const headingClip = document.querySelector(".exp__heading-clip") as HTMLElement;
    const expIndex = document.querySelector(".exp__index") as HTMLElement;

    if (!reducedMotion && expSection && headingInner && headingClip && expIndex) {
      const headingTl = gsap.timeline({
        scrollTrigger: {
          trigger: expSection,
          start: "top 75%",
          toggleActions: "play none none none",
        },
      });
      if (headingTl.scrollTrigger) localTriggers.push(headingTl.scrollTrigger);

      headingTl.to(expIndex, { opacity: 1, duration: 0.4, ease: "power2.out" });
      headingTl.to(headingInner, { opacity: 1, duration: 0.1, ease: "none" }, "-=0.5");
      headingTl.to(headingClip, { scaleX: 0, duration: 0.7, ease: "power3.inOut" }, "-=0.5");
    }

    const list = document.querySelector(".exp__list") as HTMLElement;
    const track = document.querySelector(".exp__timeline-track") as HTMLElement;
    const fill = document.querySelector(".exp__timeline-fill") as HTMLElement;
    const dot = document.querySelector(".exp__timeline-dot") as HTMLElement;
    const firstAccent = document.querySelector(".exp__accent") as HTMLElement;

    function positionTrack() {
      if (!track || !list || !firstAccent) return;
      requestAnimationFrame(() => {
        const listRect = list.getBoundingClientRect();
        const accentRect = firstAccent.getBoundingClientRect();
        track.style.left = `${accentRect.left - listRect.left}px`;
      });
    }

    if (!reducedMotion) {
      positionTrack();
      window.addEventListener("resize", positionTrack);

      if (list && fill && dot) {
        const st = {
          trigger: list,
          start: "top 60%",
          end: "bottom 40%",
          scrub: 1,
        };
        const fillTween = gsap.to(fill, { height: "100%", ease: "none", scrollTrigger: st });
        const dotTween = gsap.to(dot, { top: "100%", ease: "none", scrollTrigger: st });
        if (fillTween.scrollTrigger) localTriggers.push(fillTween.scrollTrigger);
        if (dotTween.scrollTrigger) localTriggers.push(dotTween.scrollTrigger);
      }
    }

    const rows = document.querySelectorAll("[data-exp-row]");

    function setActive(activeRow: Element) {
      rows.forEach((r) => r.classList.remove("is-active"));
      activeRow.classList.add("is-active");
    }

    if (rows.length > 0) {
      rows[0].classList.add("is-active");
    }

    rows.forEach((row, i) => {
      if (!reducedMotion) {
        gsap.set(row, { opacity: 0, y: 40 });

        const rowTween = gsap.to(row, {
          opacity: 1,
          y: 0,
          duration: 0.6,
          ease: "power2.out",
          delay: i * 0.15,
          clearProps: "opacity,transform",
          scrollTrigger: {
            trigger: row,
            start: "top 80%",
            toggleActions: "play none none none",
          },
        });
        if (rowTween.scrollTrigger) localTriggers.push(rowTween.scrollTrigger);
      }

      const accent = row.querySelector(".exp__accent") as HTMLElement;
      if (accent) {
        const enter = () => gsap.to(accent, { width: 4, duration: 0.3, ease: "power2.out" });
        const leave = () => gsap.to(accent, { width: 2, duration: 0.3, ease: "power2.out" });
        row.addEventListener("mouseenter", enter);
        row.addEventListener("mouseleave", leave);
        hoverListeners.push({ el: row, enter, leave });
      }
    });

    rows.forEach((row) => {
      const st = ScrollTrigger.create({
        trigger: row,
        start: "top center",
        end: "bottom center",
        onEnter: () => setActive(row),
        onEnterBack: () => setActive(row),
      });
      localTriggers.push(st);
    });

    document.addEventListener("astro:before-swap", () => {
      window.removeEventListener("resize", positionTrack);
      localTriggers.forEach((t) => t.kill());
      localTriggers.length = 0;
      hoverListeners.forEach(({ el, enter, leave }) => {
        el.removeEventListener("mouseenter", enter);
        el.removeEventListener("mouseleave", leave);
      });
      hoverListeners.length = 0;
    });
  }

  initExperienceAnimations();

  // Re-initialize after View Transitions navigation
  document.addEventListener("astro:after-swap", initExperienceAnimations);
</script>
