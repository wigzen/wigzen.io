---
---

<section id="contact" class="contact">
  <div class="contact__inner">
    <div class="contact__header">
      <span class="contact__index">(07)</span>
    </div>

    <p class="contact__tagline">I design systems, not just features.</p>

    <h2 class="contact__heading" data-contact-heading>
      Get in touch.
    </h2>

    <a
      href="mailto:vikaslodh2@gmail.com"
      class="contact__email"
      data-magnetic
    >
      vikaslodh2@gmail.com
    </a>

    <div class="contact__links">
      <a
        href="https://github.com/wigzen"
        target="_blank"
        rel="noopener"
        class="contact__link"
        aria-label="GitHub"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
      <a
        href="https://linkedin.com/in/vikas-lodh"
        target="_blank"
        rel="noopener"
        class="contact__link"
        aria-label="LinkedIn"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
    </div>

    <p class="contact__footer">Mumbai, India &nbsp;·&nbsp; 2026</p>
  </div>
</section>

<style>
  .contact {
    padding-block: var(--section-pad);
    padding-inline: var(--gutter);
    background: var(--clr-bg);
    border-top: 1px solid var(--clr-border);
    min-height: 80vh;
    display: flex;
    align-items: center;
  }

  .contact__inner {
    width: 100%;
  }

  .contact__header {
    margin-bottom: 2rem;
  }

  .contact__index {
    font-size: 0.8rem;
    color: var(--clr-text-muted);
    letter-spacing: 0.1em;
  }

  .contact__tagline {
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: var(--clr-accent-text);
    font-weight: 500;
    letter-spacing: 0.02em;
    margin-bottom: 1.5rem;
  }

  .contact__heading {
    font-size: var(--text-hero);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 0.9;
    color: var(--clr-text);
    margin-bottom: 3rem;
    overflow: hidden;
  }

  .contact__email {
    display: inline-block;
    font-size: clamp(1.5rem, 4vw, 3.5rem);
    font-weight: 700;
    color: var(--clr-accent);
    letter-spacing: -0.01em;
    border-bottom: 2px solid var(--clr-accent);
    padding-bottom: 0.25rem;
    margin-bottom: 4rem;
    transition: opacity 0.2s;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .contact__email:hover {
    opacity: 0.75;
  }

  .contact__links {
    display: flex;
    gap: 2rem;
    margin-bottom: 5rem;
    flex-wrap: wrap;
  }

  .contact__link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--clr-text-muted);
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }

  .contact__link:hover {
    color: var(--clr-text);
    border-color: var(--clr-border);
  }

  .contact__link i {
    font-size: 1.1rem;
  }

  .contact__footer {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--clr-text-muted);
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  gsap.registerPlugin(ScrollTrigger, SplitText);

  const heading = document.querySelector("[data-contact-heading]");
  if (heading) {
    const split = SplitText.create(heading, {
      type: "chars",
      mask: "chars",
    });

    gsap.from(split.chars, {
      yPercent: 110,
      stagger: 0.05,
      duration: 0.8,
      ease: "expo.out",
      scrollTrigger: {
        trigger: heading,
        start: "top 80%",
        toggleActions: "play none none none",
      },
    });
  }
</script>
