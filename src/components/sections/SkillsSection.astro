---
const skillSystems = [
  {
    name: "Frontend Systems",
    skills: [
      { name: "React", level: "Expert" },
      { name: "Next.js", level: "Expert" },
      { name: "Three.js", level: "Proficient" },
      { name: "WebGL", level: "Proficient" },
      { name: "TailwindCSS", level: "Expert" },
      { name: "HTML/CSS", level: "Expert" },
      { name: "JavaScript", level: "Expert" },
    ],
    projects: ["Hoopr.ai", "Hedged", "Blackcurrant Labs DApps"],
  },
  {
    name: "Backend Systems",
    skills: [
      { name: "Node.js", level: "Expert" },
      { name: "FastAPI", level: "Proficient" },
      { name: "NestJS", level: "Proficient" },
      { name: "GoLang", level: "Learning" },
      { name: "Python", level: "Expert" },
    ],
    projects: ["Cybic AI RAG Pipeline", "Bryt Schools Data Pipelines"],
  },
  {
    name: "Data & Storage",
    skills: [
      { name: "PostgreSQL", level: "Expert" },
      { name: "Redis", level: "Expert" },
      { name: "Vector DBs", level: "Proficient" },
      { name: "Firebase", level: "Proficient" },
    ],
    projects: ["Cybic AI Tokenisation", "Hoopr.ai Search"],
  },
  {
    name: "Infrastructure & DevOps",
    skills: [
      { name: "AWS", level: "Proficient" },
      { name: "Docker", level: "Proficient" },
      { name: "Git", level: "Expert" },
      { name: "Linux", level: "Proficient" },
      { name: "CI/CD", level: "Proficient" },
    ],
    projects: ["Bryt Schools Platform", "All Production Deployments"],
  },
  {
    name: "AI / ML / Security",
    skills: [
      { name: "Presidio", level: "Proficient" },
      { name: "NeMo Guardrails", level: "Proficient" },
      { name: "RAG Systems", level: "Proficient" },
      { name: "Google NLP", level: "Proficient" },
      { name: "Solidity", level: "Learning" },
    ],
    projects: ["Cybic AI Secure RAG", "Zotech NLP Phraser"],
  },
];

function getLevelWidth(level: string): string {
  switch (level) {
    case "Expert": return "90%";
    case "Proficient": return "70%";
    case "Learning": return "40%";
    default: return "50%";
  }
}
---

<section id="skills" class="skills">
  <div class="skills__header">
    <span class="skills__index">(05)</span>
    <h2 class="skills__heading">Skills</h2>
  </div>

  <p class="skills__intro" data-skills-intro>
    Skills organised as interconnected systems — not isolated keywords.
  </p>

  <div class="skills__grid">
    {skillSystems.map((system) => (
      <article class="skills__system" data-skills-system>
        <h3 class="skills__system-name">{system.name}</h3>
        <ul class="skills__list">
          {system.skills.map((skill) => (
            <li class="skills__item">
              <div class="skills__item-header">
                <span class="skills__item-name">{skill.name}</span>
                <span class="skills__item-level">{skill.level}</span>
              </div>
              <div class="skills__bar-track">
                <div
                  class="skills__bar-fill"
                  data-skills-bar
                  style={`--bar-width: ${getLevelWidth(skill.level)}`}
                />
              </div>
            </li>
          ))}
        </ul>
        <div class="skills__system-projects">
          <span class="skills__projects-label">Used in:</span>
          {system.projects.map((p) => (
            <span class="skills__project-tag">{p}</span>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .skills {
    padding-block: var(--section-pad);
    padding-inline: var(--gutter);
    background: var(--clr-bg);
  }

  .skills__header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .skills__index {
    font-size: 0.8rem;
    color: var(--clr-text-muted);
    letter-spacing: 0.1em;
  }

  .skills__heading {
    font-size: var(--text-h2);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--clr-text);
  }

  .skills__intro {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    color: var(--clr-text-muted);
    margin-bottom: 4rem;
    max-width: 50ch;
  }

  .skills__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3rem;
  }

  .skills__system {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    background: var(--clr-surface);
    transition: border-color 0.3s ease;
  }

  .skills__system:hover {
    border-color: var(--clr-accent);
  }

  .skills__system-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--clr-text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .skills__list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .skills__item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .skills__item-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .skills__item-name {
    font-size: 0.85rem;
    color: var(--clr-text);
    font-weight: 500;
  }

  .skills__item-level {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--clr-text-muted);
  }

  .skills__bar-track {
    width: 100%;
    height: 3px;
    background: var(--clr-border);
    border-radius: 2px;
    overflow: hidden;
  }

  .skills__bar-fill {
    height: 100%;
    width: 0;
    background: var(--clr-accent-fill);
    border-radius: 2px;
    transition: width 0.8s var(--ease-smooth);
  }

  .skills__system-projects {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--clr-border);
  }

  .skills__projects-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--clr-text-muted);
    margin-right: 0.5rem;
  }

  .skills__project-tag {
    font-size: 0.65rem;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-full);
    color: var(--clr-text-muted);
  }

  @media (max-width: 640px) {
    .skills__grid {
      grid-template-columns: 1fr;
    }

    .skills__system {
      padding: 1.5rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const localTriggers: globalThis.ScrollTrigger[] = [];

  document.querySelectorAll("[data-skills-system]").forEach((system, i) => {
    const tween = gsap.from(system, {
      opacity: 0,
      y: 30,
      duration: 0.6,
      delay: i * 0.1,
      ease: "power3.out",
      scrollTrigger: {
        trigger: system,
        start: "top 85%",
        toggleActions: "play none none none",
      },
    });
    if (tween.scrollTrigger) localTriggers.push(tween.scrollTrigger);

    const bars = system.querySelectorAll("[data-skills-bar]");
    bars.forEach((bar) => {
      const targetWidth = (bar as HTMLElement).style.getPropertyValue("--bar-width");
      const st = ScrollTrigger.create({
        trigger: bar,
        start: "top 90%",
        onEnter: () => {
          (bar as HTMLElement).style.width = targetWidth;
        },
      });
      localTriggers.push(st);
    });
  });

  document.addEventListener("astro:before-swap", () => {
    localTriggers.forEach((t) => t.kill());
    localTriggers.length = 0;
  });
</script>
