---
const navItems = [
  { id: "home", label: "Home", href: "#home" },
  { id: "about", label: "About", href: "#about" },
  { id: "work", label: "Work", href: "#work" },
  { id: "systems", label: "Systems", href: "#systems" },
  { id: "skills", label: "Skills", href: "#skills" },
  { id: "lab", label: "Lab", href: "#lab" },
  { id: "contact", label: "Contact", href: "#contact" },
];
---

<nav class="nav" id="mainNav" style="opacity:0" aria-label="Main navigation">
  <ul class="nav__menu">
    {
      navItems.map((item) => (
        <li class="nav__item">
          <a
            href={item.href}
            class={`nav__link ${item.id === "home" ? "active" : ""}`}
            data-id={item.id}
          >
            {item.label}
          </a>
        </li>
      ))
    }
    <span class="nav__menu-indicator"></span>
  </ul>
</nav>

<style>
  /* Navigation Variables */
  :root {
    --custom: cubic-bezier(0.76, 0, 0.24, 1);
    --smooth: cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Navigation Container */
  .nav {
    position: fixed;
    bottom: 2.4rem;
    left: 0;
    right: 0;
    margin: auto;
    width: fit-content;
    z-index: 1000;
  }

  /* Menu Styling */
  .nav__menu {
    display: flex;
    background-color: var(--nav-bg-color);
    border-radius: 1.4rem;
    padding-block: 0.2rem;
    position: relative;
    backdrop-filter: blur(12px);
    border: 1px solid var(--clr-border);
  }

  .nav__item {
    position: relative;
    z-index: 2;
  }

  .nav__link {
    display: block;
    padding: 0.5rem 1rem;
    color: var(--nav-text-color);
    text-decoration: none;
    border-radius: 1.4rem;
    transition: color 0.3s var(--smooth);
    font-size: 0.875rem;
    position: relative;
    z-index: 3;
  }

  .nav__link.active {
    color: var(--nav-active-text-color);
    font-weight: 500;
  }

  /* Animated Indicator */
  .nav__menu-indicator {
    position: absolute;
    display: block;
    top: 0.2rem;
    left: 0;
    height: calc(100% - 0.4rem);
    width: 5rem;
    background-color: var(--nav-active-color, #a8ff51);
    z-index: 1;
    border-radius: 1.2rem;
    will-change: transform, width;
  }

  @media (max-width: 480px) {
    .nav__link {
      padding: 0.4rem 0.75rem;
      font-size: 0.8rem;
    }

    .nav__menu-indicator {
      border-radius: 1rem;
    }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const nav = document.querySelector(".nav") as HTMLElement | null;
  const navLinks = nav?.querySelectorAll(
    ".nav__link"
  ) as NodeListOf<HTMLAnchorElement> | null;
  const menuIndicator = nav?.querySelector(
    ".nav__menu-indicator"
  ) as HTMLElement | null;
  const navMenu = nav?.querySelector(".nav__menu") as HTMLElement | null;

  function getPositionOfElement(element: HTMLElement): number {
    if (!element || !navMenu) return 0;
    const navRect = navMenu.getBoundingClientRect();
    const elementRect = element.getBoundingClientRect();
    return elementRect.left - navRect.left;
  }

  function setActive(id: string) {
    if (!navLinks || !menuIndicator) return;
    // Guard: only act if there's a matching nav item
    const activeLink = nav?.querySelector(
      `[data-id="${id}"]`
    ) as HTMLElement | null;
    if (!activeLink) return;
    navLinks.forEach((l) => l.classList.remove("active"));
    activeLink.classList.add("active");
    const { width } = activeLink.getBoundingClientRect();
    const position = getPositionOfElement(activeLink);
    gsap.to(menuIndicator, {
      x: position,
      width,
      duration: 0.4,
      ease: "power3.out",
    });
  }

  function initializeIndicator(): void {
    if (!menuIndicator || !navLinks) return;
    const activeLink = nav?.querySelector(
      ".nav__link.active"
    ) as HTMLElement | null;
    if (activeLink) {
      const { width } = activeLink.getBoundingClientRect();
      const position = getPositionOfElement(activeLink);
      gsap.set(menuIndicator, { width, x: position });
    }
  }

  // Click handlers
  navLinks?.forEach((link) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      const id = link.dataset.id || "";
      setActive(id);
      // Smooth scroll to section
      const target = document.getElementById(id === "home" ? "home" : id);
      target?.scrollIntoView({ behavior: "smooth" });
    });
  });

  // Reveal navbar after loader completes
  function revealNav() {
    if (!nav) return;
    initializeIndicator();
    gsap.to(nav, { opacity: 1, y: 0, duration: 0.5, ease: "power2.out" });
  }

  gsap.set(nav, { y: 20 });

  if ((window as any).__introComplete) {
    revealNav();
  } else {
    document.addEventListener("intro:complete", revealNav, { once: true });
  }

  // ScrollTrigger-based active state — only sections that have nav items
  const sectionIds = ["home", "about", "work", "systems", "skills", "lab", "contact"];
  sectionIds.forEach((id) => {
    const section = document.getElementById(id);
    if (!section) return;
    ScrollTrigger.create({
      trigger: section,
      start: "top 50%",
      end: "bottom 50%",
      onEnter: () => setActive(id),
      onEnterBack: () => setActive(id),
    });
  });

  document.addEventListener("DOMContentLoaded", initializeIndicator);
</script>
