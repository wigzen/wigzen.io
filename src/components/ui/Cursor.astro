---

---

<div id="cursor">
  <div class="cursor__dot"></div>
  <div class="cursor__ring"></div>
</div>

<style>
  #cursor {
    pointer-events: none;
    position: fixed;
    top: 0;
    left: 0;
    z-index: 99999;
  }

  .cursor__dot {
    width: 6px;
    height: 6px;
    background: #a8ff51;
    border-radius: 50%;
    position: fixed;
    top: 0;
    left: 0;
    /* translate: -50% -50% handled by JS via style.transform so it centers
       without GSAP touching this element at all */
    pointer-events: none;
    will-change: transform;
  }

  .cursor__ring {
    width: 32px;
    height: 32px;
    border: 2px solid #a8ff51;
    border-radius: 50%;
    position: fixed;
    top: 0;
    left: 0;
    translate: -50% -50%;
    pointer-events: none;
    will-change: transform;
  }

  /* Hide on touch devices / tablets / mobile */
  @media (max-width: 1024px), (hover: none) {
    #cursor {
      display: none !important;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  // Module-level refs — only one set of listeners ever lives on window/document
  let cursorObserver: MutationObserver | null = null;
  let _onMouseMove: ((e: MouseEvent) => void) | null = null;
  let _onMouseOver: ((e: MouseEvent) => void) | null = null;
  let _onMouseOut: ((e: MouseEvent) => void) | null = null;
  let _onThemeChange: (() => void) | null = null;

  function cleanupCursor() {
    cursorObserver?.disconnect();
    cursorObserver = null;
    if (_onMouseMove) {
      window.removeEventListener("mousemove", _onMouseMove);
      _onMouseMove = null;
    }
    if (_onMouseOver) {
      document.removeEventListener("mouseover", _onMouseOver);
      _onMouseOver = null;
    }
    if (_onMouseOut) {
      document.removeEventListener("mouseout", _onMouseOut);
      _onMouseOut = null;
    }
    if (_onThemeChange) {
      document.removeEventListener("theme:change", _onThemeChange);
      _onThemeChange = null;
    }
  }

  function initCursor() {
    cleanupCursor(); // wipe any previous listeners before re-attaching

    const hasHover = window.matchMedia("(hover: hover)").matches;
    const isDesktop = window.innerWidth > 1024;
    if (!hasHover || !isDesktop) return;

    const cursor = document.getElementById("cursor");
    const dot = document.querySelector(".cursor__dot") as HTMLElement;
    const ring = document.querySelector(".cursor__ring") as HTMLElement;
    if (!dot || !ring || !cursor) return;

    function isDarkMode(): boolean {
      return (
        document.body.classList.contains("theme-dark") ||
        document.documentElement.classList.contains("theme-dark")
      );
    }

    function updateCursorVisibility(): void {
      gsap.to(cursor!, {
        opacity: isDarkMode() ? 1 : 0,
        duration: 0.3,
        overwrite: true,
      });
    }

    gsap.set(cursor, { opacity: isDarkMode() ? 1 : 0 });

    _onThemeChange = updateCursorVisibility;
    document.addEventListener("theme:change", _onThemeChange);

    cursorObserver = new MutationObserver(updateCursorVisibility);
    cursorObserver.observe(document.body, {
      attributes: true,
      attributeFilter: ["class"],
    });

    _onMouseMove = (e: MouseEvent) => {
      // Dot: direct CSS transform — no GSAP, no frame budget, GPU-composited
      dot.style.transform = `translate(calc(${e.clientX}px - 50%), calc(${e.clientY}px - 50%))`;
      // Ring: GSAP-only for the intentional lag/ease
      gsap.to(ring, {
        x: e.clientX,
        y: e.clientY,
        duration: 0.35,
        ease: "power2.out",
        overwrite: true,
      });
    };

    const hoverTargets = "a, button, [data-magnetic]";
    _onMouseOver = (e: MouseEvent) => {
      if ((e.target as HTMLElement).closest(hoverTargets))
        gsap.to(ring, { scale: 2.5, duration: 0.3, ease: "power2.out" });
    };
    _onMouseOut = (e: MouseEvent) => {
      if ((e.target as HTMLElement).closest(hoverTargets))
        gsap.to(ring, { scale: 1, duration: 0.3, ease: "power2.out" });
    };

    window.addEventListener("mousemove", _onMouseMove);
    document.addEventListener("mouseover", _onMouseOver);
    document.addEventListener("mouseout", _onMouseOut);
  }

  initCursor();
  document.addEventListener("astro:before-swap", cleanupCursor);
  document.addEventListener("astro:after-swap", initCursor);
</script>
