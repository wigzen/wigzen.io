---
---

<div id="cursor">
  <div class="cursor__dot"></div>
  <div class="cursor__ring"></div>
</div>

<style>
  #cursor {
    pointer-events: none;
    position: fixed;
    top: 0;
    left: 0;
    z-index: 99999;
  }

  .cursor__dot {
    width: 8px;
    height: 8px;
    background: #a8ff51;
    border-radius: 50%;
    position: fixed;
    top: 0;
    left: 0;
    translate: -50% -50%;
    pointer-events: none;
  }

  .cursor__ring {
    width: 32px;
    height: 32px;
    border: 2px solid #a8ff51;
    border-radius: 50%;
    position: fixed;
    top: 0;
    left: 0;
    translate: -50% -50%;
    pointer-events: none;
  }
</style>

<script>
  import { gsap } from "gsap";

  const cursor = document.getElementById("cursor");
  const dot = document.querySelector(".cursor__dot") as HTMLElement;
  const ring = document.querySelector(".cursor__ring") as HTMLElement;

  if (dot && ring && cursor) {
    function isDarkMode(): boolean {
      return document.body.classList.contains("theme-dark");
    }

    function updateCursorVisibility(): void {
      gsap.to(cursor!, {
        opacity: isDarkMode() ? 1 : 0,
        duration: 0.3,
        overwrite: true,
      });
    }

    gsap.set(cursor, { opacity: isDarkMode() ? 1 : 0 });

    document.addEventListener("theme:change", updateCursorVisibility);

    window.addEventListener("mousemove", (e: MouseEvent) => {
      gsap.to(dot, {
        x: e.clientX,
        y: e.clientY,
        duration: 0.05,
        overwrite: true,
      });
      gsap.to(ring, {
        x: e.clientX,
        y: e.clientY,
        duration: 0.35,
        ease: "power2.out",
        overwrite: true,
      });
    });

    const hoverTargets = "a, button, [data-magnetic]";

    document.addEventListener("mouseover", (e: MouseEvent) => {
      if ((e.target as HTMLElement).closest(hoverTargets)) {
        gsap.to(ring, { scale: 2.5, duration: 0.3, ease: "power2.out" });
      }
    });

    document.addEventListener("mouseout", (e: MouseEvent) => {
      if ((e.target as HTMLElement).closest(hoverTargets)) {
        gsap.to(ring, { scale: 1, duration: 0.3, ease: "power2.out" });
      }
    });
  }
</script>
