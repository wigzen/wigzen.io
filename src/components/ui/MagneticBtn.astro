---
interface Props {
  tag?: string;
  href?: string;
  class?: string;
}
const { tag = "div", href, class: className = "" } = Astro.props;
const Tag = tag as any;
---

<Tag
  href={href}
  class={`magnetic-btn ${className}`}
  data-magnetic
>
  <slot />
</Tag>

<style>
  .magnetic-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
</style>
