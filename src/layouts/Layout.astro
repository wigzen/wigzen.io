---
import { ViewTransitions } from "astro:transitions";
import "/src/global.css";
import Cursor from "../components/ui/Cursor.astro";
import ThemeToggle from "../components/ui/ThemeToggle.astro";
import SEO from "../components/SEO.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Vikas Lodh | Full Stack Engineer & Systems Architect",
  description,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="shortcut icon" href="/img/icon.png" type="image/x-icon" />
    <meta name="generator" content={Astro.generator} />
    <SEO title={title} description={description} />
    <ViewTransitions />
    <title>{title}</title>
    <!-- Restore theme preference before paint -->
    <script is:inline>
      (function(){
        function getIsDark() {
          var theme = localStorage.getItem('theme');
          return theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches);
        }
        function applyThemeEarly() {
          var isDark = getIsDark();
          document.documentElement.style.setProperty('--initial-bg', isDark ? '#0a0a0a' : '#f5f5f0');
          document.documentElement.classList.toggle('theme-dark', isDark);
          if (document.body) {
            document.body.classList.toggle('theme-dark', isDark);
          }
        }
        applyThemeEarly();
        document.addEventListener('DOMContentLoaded', applyThemeEarly, { once: true });
        // Re-apply after ViewTransitions page swap
        document.addEventListener('astro:after-swap', applyThemeEarly);
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-nav">Skip to content</a>
    <!-- Static placeholder covers page until Solid Counter hydrates -->
    <div id="loader-placeholder" style="position:fixed;inset:0;background:var(--initial-bg, #0a0a0a);z-index:9999;pointer-events:none"></div>
    <script is:inline>
      // On pages without Loader, remove the placeholder immediately
      (function() {
        function removeIfNoLoader() {
          if (!document.getElementById('loader-wrapper')) {
            var el = document.getElementById('loader-placeholder');
            if (el) el.remove();
          }
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', removeIfNoLoader, { once: true });
        } else {
          removeIfNoLoader();
        }
      })();
    </script>
    <Cursor />
    <ThemeToggle />
    <div id="main-content">
      <slot />
    </div>
  </body>
</html>

<script>
  import Lenis from "@studio-freight/lenis";
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Apply theme from localStorage before anything else
  (function applyTheme() {
    const saved = localStorage.getItem('theme');
    const isDark = saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches);
    document.documentElement.classList.toggle('theme-dark', isDark);
    document.body.classList.toggle('theme-dark', isDark);
  })();

  const lenis = new Lenis({
    duration: 1.2,
    easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
  });

  gsap.ticker.add((time: number) => lenis.raf(time * 1000));
  gsap.ticker.lagSmoothing(0);
  lenis.on("scroll", ScrollTrigger.update);

  // Magnetic buttons
  document.querySelectorAll("[data-magnetic]").forEach((el) => {
    const btn = el as HTMLElement;
    btn.addEventListener("mousemove", (e: MouseEvent) => {
      const r = btn.getBoundingClientRect();
      gsap.to(btn, {
        x: (e.clientX - r.left - r.width / 2) * 0.4,
        y: (e.clientY - r.top - r.height / 2) * 0.4,
        duration: 0.3,
        ease: "power2.out",
      });
    });
    btn.addEventListener("mouseleave", () => {
      gsap.to(btn, { x: 0, y: 0, duration: 0.5, ease: "elastic.out(1, 0.4)" });
    });
  });
</script>
